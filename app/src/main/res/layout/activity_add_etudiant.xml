<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <!-- Titre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ajouter un Étudiant"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Nom -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nom"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etNom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Entrez le nom"
        android:inputType="textPersonName"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="16dp"/>

    <!-- Prénom -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Prénom"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etPrenom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Entrez le prénom"
        android:inputType="textPersonName"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="16dp"/>

    <!-- Ville -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ville"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etVille"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Entrez la ville"
        android:inputType="textPostalAddress"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="16dp"/>

    <!-- Sexe -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sexe"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etSexe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="homme / femme"
        android:inputType="text"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="32dp"/>

    <!-- Bouton Ajouter -->
    <Button
        android:id="@+id/btnAjouter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ajouter"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3F51B5"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- Bouton Annuler -->
    <Button
        android:id="@+id/btnAnnuler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Annuler"
        android:textSize="16sp"
        android:textColor="#3F51B5"
        android:backgroundTint="#FFFFFF"
        android:padding="12dp"/>

</LinearLayout>